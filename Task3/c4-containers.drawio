<mxfile host="app.diagrams.net" modified="2026-04-19T00:00:00.000Z" agent="drawio" version="24.0.0" type="device">
  <diagram name="C4-Containers-SmartHome" id="c4-containers">
    <mxGraphModel dx="2200" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="C4 Level 2 — Контейнеры PropDevelopment с интеграцией «Умный дом». Новые компоненты выделены жёлтым." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="owner" value="&lt;b&gt;Собственник&lt;/b&gt;&lt;div&gt;[Person]&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=12;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="propBoundary" value="PropDevelopment" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#444444;dashed=1;fontSize=14;fontStyle=1;align=left;verticalAlign=top;fontColor=#444444" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="1220" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="zkuBoundary" value="Домен ЖКУ (+ shared IAM)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;dashed=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fontColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="340" y="110" width="1180" height="780" as="geometry" />
        </mxCell>

        <mxCell id="mobile" value="&lt;b&gt;Мобильное приложение&lt;/b&gt;&lt;div&gt;[Container: iOS/Android]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Приложение собственника. ЖКУ + новый раздел «Умный дом»&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="360" y="160" width="220" height="110" as="geometry" />
        </mxCell>

        <mxCell id="webShow" value="&lt;b&gt;Витрина ЖКУ&lt;/b&gt;&lt;div&gt;[Container: Web]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Веб-вход собственников (существующий)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="360" y="310" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="apigw" value="&lt;b&gt;API Gateway партнёрских интеграций&lt;/b&gt; (NEW)&lt;div&gt;[Container: API Gateway]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Единая точка входа ко всем партнёрам. Валидация токенов, rate-limit, mTLS egress, подпись webhook-ов&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="620" y="160" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="idp" value="&lt;b&gt;IdP / служба каталогов&lt;/b&gt;&lt;div&gt;[Container: OAuth2 / OIDC]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Расширение существующей службы каталогов на все домены. MFA, SSO, RBAC/ABAC&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="620" y="310" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="bus" value="&lt;b&gt;event-bus&lt;/b&gt; (NEW)&lt;div&gt;[Container: Kafka]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Асинхронный канал для событий устройств и уведомлений собственников&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="620" y="450" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sha" value="&lt;b&gt;smart-home-app&lt;/b&gt; (NEW)&lt;div&gt;[Container: Service]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Доменный сервис Умного дома: enrollment биометрии, права доступа, команды открытия, ABAC-политика&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="910" y="160" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="shdb" value="&lt;b&gt;smart-home-db&lt;/b&gt; (NEW)&lt;div&gt;[Container: PostgreSQL]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Embeddings (обезличенные), номера авто, права доступа, аудит. AES-256 at rest&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="910" y="310" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="tca" value="&lt;b&gt;tenant-core-app&lt;/b&gt;&lt;div&gt;[Container: Service]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Основной сервис услуг собственникам (ЖКУ, ремонты, Умный дом — базовый уровень)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1200" y="160" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="tcdb" value="&lt;b&gt;tenant-core-db&lt;/b&gt;&lt;div&gt;[Container: DB]&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1200" y="310" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="crm" value="&lt;b&gt;CRM собственников&lt;/b&gt;&lt;div&gt;[Container: Service]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Управление данными собственников (источник активных инцидентов ЛК)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1200" y="430" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="crmdb" value="&lt;b&gt;CRM-db&lt;/b&gt;&lt;div&gt;[Container: DB]&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1200" y="570" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="others" value="&lt;b&gt;Другие домены PropDevelopment&lt;/b&gt;&lt;div&gt;Продажи (client-crm, client-mart, client-tour, витрина продаж), Финансы (accountant, служба каталогов как часть IdP), Данные (DWH, BI, отчётность)&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:6px&quot;&gt;В рамках Task3 без изменений. Связаны с IdP и event-bus&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DDE8F4;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="360" y="740" width="1140" height="120" as="geometry" />
        </mxCell>

        <mxCell id="partner" value="&lt;b&gt;Платформа партнёра «Умный дом»&lt;/b&gt;&lt;div&gt;[External System]&lt;/div&gt;&lt;div style=&quot;font-size:10px;margin-top:4px&quot;&gt;Облачная платформа управления устройствами, распознавание лиц и номеров&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1600" y="200" width="240" height="130" as="geometry" />
        </mxCell>

        <mxCell id="intercom" value="&lt;b&gt;Интеллектуальный домофон&lt;/b&gt;&lt;div&gt;[External Device]&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;fontSize=11;dashed=1;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1600" y="370" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="barrier" value="&lt;b&gt;Интеллектуальный шлагбаум&lt;/b&gt;&lt;div&gt;[External Device]&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;fontSize=11;dashed=1;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="1600" y="470" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="c1" value="Использует [HTTPS + pinning]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="owner" target="mobile"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="c2" value="REST / HTTPS&#10;OAuth2 (PKCE) + MFA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="mobile" target="apigw"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3" value="Валидация токена&#10;(JWKS / introspection)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="apigw" target="idp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c4" value="REST с JWT (scope smart-home:*)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="apigw" target="sha"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c5" value="ABAC check" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="sha" target="idp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c6" value="SQL / TLS&#10;AES-256 at rest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="sha" target="shdb"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="c7" value="Команды, enrollment&#10;[mTLS + OAuth2 Client Credentials]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="apigw" target="partner"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c8" value="Signed webhook&#10;[HMAC-SHA256]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="partner" target="apigw"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="c9" value="publish device events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="apigw" target="bus"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c10" value="consume events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="bus" target="sha"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c11" value="notify" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="bus" target="tca"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="c12" value="Карта собственник↔квартира↔ЖК&#10;[gRPC / mTLS]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="sha" target="crm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c13" value="SQL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="crm" target="crmdb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c14" value="ЖКУ / ремонты&#10;[существующие вызовы]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="tca" target="tcdb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c15" value="данные собственников" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="tca" target="crm"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="c16" value="существующие вызовы" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="mobile" target="tca"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c17" value="логин" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="mobile" target="idp"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="c18" value="Команды, распознавание" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="partner" target="intercom"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c19" value="Команды, ANPR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="partner" target="barrier"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="legend" value="&lt;b&gt;Легенда&lt;/b&gt;&lt;br&gt;■ Синий заполненный — существующий контейнер PropDevelopment&lt;br&gt;■ Жёлтый — новый контейнер (добавлен в рамках Task3)&lt;br&gt;■ Тёмно-синий — пользователь (Person)&lt;br&gt;■ Серый — внешние системы и устройства партнёра&lt;br&gt;Сплошная стрелка — синхронный вызов, пунктир — асинхронный/служебный&lt;br&gt;Пунктирная рамка — системная / доменная граница" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="60" y="900" width="500" height="150" as="geometry" />
        </mxCell>

      </root>
